# Chaîne de connexion du projet Neon « ebok » (schéma medias créé automatiquement).
# Console Neon → ton projet → Connection string (avec ?sslmode=require).
# Tant qu'elle est absente : le site reste statique, le formulaire propose l'e-mail.
DATABASE_URL=

# Mot de passe de l'administrateur de l'annuaire (page /admin).
# Provisoire, en attendant le compte unique EBOK (Clerk).
ADMIN_PASSWORD=
